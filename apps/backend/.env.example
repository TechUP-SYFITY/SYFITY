# 서버 포트
PORT=4000

# FE 클라이언트 주소
CLIENT_URL=http://localhost:3000

# CORS 허용 origin (쉼표 구분)
ALLOWED_ORIGINS=http://localhost:3000

# JWT 시크릿 키
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# Supabase 데이터베이스 URL
# 로컬: postgresql://postgres:postgres@127.0.0.1:54322/postgres
# 운영: Supabase 클라우드 Connection String
DATABASE_URL=

# YouTube Data API v3 키
YOUTUBE_API_KEY=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=
